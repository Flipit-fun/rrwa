// RRWA off-chain metadata. On-chain is the source of truth for money and
// state; this DB holds descriptive metadata that doesn't belong on-chain.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Isolate RRWA tables in their own schema so they never touch other
  // projects' tables living in `public` on this shared database.
  schemas  = ["rrwa"]
}

enum AssetType {
  RESIDENTIAL
  COMMERCIAL
  WAREHOUSE
  LAND
  INFRASTRUCTURE
  OTHER

  @@schema("rrwa")
}

enum KybStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED

  @@schema("rrwa")
}

enum PayoutStatus {
  REQUESTED
  PAID
  DECLINED

  @@schema("rrwa")
}

enum PayoutKind {
  WITHDRAWAL // return of principal
  YIELD // yield/interest payout

  @@schema("rrwa")
}

/// A record of USDG sent directly to a property's dedicated treasury wallet
/// (plain ERC-20 transfer, no pool contract). Scoped to one Asset — each
/// property has its own wallet, so a deposit only ever counts toward that
/// property's yield and withdrawal limit. `depositor` self-reports the tx
/// hash after sending, which we can spot-check against the explorer.
model PoolDeposit {
  id         String   @id @default(cuid())
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId    String
  depositor  String // wallet address, lowercased
  amountUsdc String // USDG base units as string (bigint-safe)
  txHash     String   @unique
  createdAt  DateTime @default(now())

  @@index([depositor])
  @@index([assetId])
  @@schema("rrwa")
}

/// A withdrawal or yield-payout request against one property's pool. There
/// is no automated payment logic — the RRWA team reviews these and pays out
/// manually from that property's treasury wallet, then marks the request
/// PAID (with the payout tx hash for reference). A withdrawal can never
/// exceed what the requester has deposited into that specific property
/// (enforced in the server action, not just the UI).
model PayoutRequest {
  id           String       @id @default(cuid())
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId      String
  requester    String // wallet address, lowercased
  kind         PayoutKind
  amountUsdc   String // USDG base units requested, as string
  status       PayoutStatus @default(REQUESTED)
  payoutTxHash String?
  note         String? // optional note from the requester
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([requester])
  @@index([assetId])
  @@schema("rrwa")
}

/// One row per listing application. Starts as an off-chain application
/// (PENDING review); the on-chain raise (raiseAddress) is only linked once
/// RRWA has reviewed the KYC and the lister goes on to create it.
model Asset {
  id            String     @id @default(cuid())
  // On-chain link. Null until the raise is created on-chain, then backfilled.
  raiseAddress  String?    @unique
  lister        String // wallet address of the lister
  name          String
  streetAddress String? // full street address, kept private from public pages if needed
  city          String
  region        String // state/province/country label
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Int?
  description   String
  assetType     AssetType
  // Cached listing terms (authoritative copy lives on-chain once created).
  targetUsdc    String // USDC base units as string (bigint-safe)
  apyBps        Int
  kybStatus     KybStatus  @default(PENDING)
  coverImageUrl String?
  latitude      Float?
  longitude     Float?
  // Infrastructure/RWA fund-style listings (vs. single residential
  // properties) surface these instead of bedrooms/bathrooms/sqft.
  sector          String? // e.g. "Renewable Energy", "Aquaculture"
  capacityPct     Int? // utilization/occupancy capacity, 0-100
  operatingStatus String  @default("ACTIVE") // ACTIVE | PAUSED | CLOSED
  // Per-wallet investment bounds shown as a preview before the on-chain
  // Raise exists. USDG base units as strings (bigint-safe). Once a Raise is
  // deployed and linked via raiseAddress, the real on-chain values (read
  // from Raise.minContribution/maxContribution) are authoritative and these
  // are just the pre-launch preview shown to prospective investors.
  minContributionUsdc String?
  maxContributionUsdc String?
  // This property's dedicated treasury wallet. Investing means sending USDG
  // directly here; withdrawals/yield for this property are paid out
  // manually from this same wallet by the RRWA team. Null until assigned.
  treasuryAddress String?
  images        AssetImage[]
  kybDocs       KybDoc[]
  kyc           Kyc?
  deposits      PoolDeposit[]
  payoutRequests PayoutRequest[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([lister])
  @@index([raiseAddress])
  @@schema("rrwa")
}

/// Individual identity KYC captured during the listing application. No
/// automated verification provider is wired up yet — a human on the RRWA
/// team reviews this manually (see AGENTS discussion: "KYC comes later").
model Kyc {
  id            String   @id @default(cuid())
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId       String   @unique

  // Identity
  fullName      String
  country       String // country of residence/citizenship
  dateOfBirth   DateTime
  idType        String // e.g. PASSPORT, DRIVING_LICENSE, NATIONAL_ID — options depend on `country`
  idNumber      String

  // Contact
  phone         String
  email         String
  residentialAddress String

  // Family / next of kin
  fatherName          String?
  motherName          String?
  maritalStatus       String?
  emergencyContactName  String?
  emergencyContactPhone String?

  // Socials (collected on the final step of the application)
  xHandle       String?
  telegramHandle String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@schema("rrwa")
}

model AssetImage {
  id      String @id @default(cuid())
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId String
  url     String
  alt     String?
  sort    Int    @default(0)

  @@index([assetId])
  @@schema("rrwa")
}

model KybDoc {
  id        String    @id @default(cuid())
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId   String
  label     String
  url       String
  status    KybStatus @default(SUBMITTED)
  createdAt DateTime  @default(now())

  @@index([assetId])
  @@schema("rrwa")
}
